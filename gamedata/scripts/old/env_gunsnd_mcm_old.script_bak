function playSound(parent, sec, param, volume)
	if not (sec and param and ini_sys:r_string_ex(sec, param)) then return end
	if ini_sys:r_string_ex(ini_sys:r_string_ex(sec, param), "snd_1_layer") then
		local paramCount = getSndParamCount(sec,param)
		for i = 1,#paramCount do
			local j = math.random(0,paramCount[i])
			if j == 0 then j="" end
			local file = ini_sys:r_string_ex(ini_sys:r_string_ex(sec, param), "snd_"..i.."_layer"..j)
			local sound = xr_sound.get_safe_sound_object(file)
			sound:play_no_feedback(parent, 0, 0, parent:position(), volume, 1)
		end
	elseif string.find(ini_sys:r_string_ex(sec, param),"\\") then
		local sound = xr_sound.get_safe_sound_object(ini_sys:r_string_ex(sec, param))
		sound:play_no_feedback(parent, 0, 0, parent:position(), volume, 1)
	end
end

function playTail(parent,indoor_score,avg_lenght)
    if not (parent and parent:alive()) then return end
	local wpn = parent:active_item()
	local sec = get_wp_sec(parent)
	local volume_transistion = (indoor_score-mcm_settings.new_threshold[1])/(1-mcm_settings.new_threshold[1])
	if indoor_score>mcm_settings.new_threshold[1] then
		local param = "snd_tail_indoor"
		if wpn and wpn:cast_Weapon():IsSilencerAttached() then param = "snd_silncer_tail_indoor" end
		local volume = mcm_settings.volume[1]*volume_transistion*mcm_settings.tail_volume[1]*tail_volume_equation(avg_lenght/mcm_settings.tail_length[1])*3
		if ini_sys:r_string_ex(sec,param) then
			playSound(parent, sec, param, volume)
		elseif mcm_settings.bak_tail[1] and not wpn:cast_Weapon():IsSilencerAttached() then
			local sound = xr_sound.get_safe_sound_object("weapons\\indoor\\bak\\npc\\indoor_simulation_"..math.random(1,4))
			sound:play_no_feedback(parent, 0, 0, parent:position(), volume, 1)
		end
	end
end

function fireRayForNPC(dir,lenght,parent)
	local pos = getPos(parent)
	local point = 0
	local total_lenght = 0
	local bounced = 0
	local ray_count_count_for_npc = mcm_settings.npc_ray_bounce_count[1]
	for bounce = 1,ray_count_count_for_npc do
		local ray_args = {
			ray_range = lenght*(1/bounce)*mcm_settings.ray_lenght_mult[1],
			contact_range = lenght*(1/bounce)*mcm_settings.ray_lenght_mult[1]-0.01,
			flags = (1 + 2),
			ignore_object = parent,
			visualize = mcm_settings.ray_dbug[1]
		}
		local ray = demonized_geometry_ray.geometry_ray(ray_args)
		local result = ray:get(vector():set(pos), dir)

		-- This loop checks if the contact surface is a bush, and re-casts the ray just inside it if it is -- By Ujtan
		while result.in_contact and result.result.material_name do
			local name = result.result.material_name
			if not isBlackListedMaterial(name) then
				break -- break out of the loop if contact is not a bush
			end
			ray_args.ray_range = ray_args.ray_range - result.distance
			ray_args.contact_range = ray_args.contact_range - result.distance
			ray = demonized_geometry_ray.geometry_ray(ray_args)
			local new_pos = vector():set(result.position):add(vector():set(dir):mul(0.1))
			result = ray:get(new_pos, dir)
		end
		if result.in_contact then
			point = point+bounce
			total_lenght = total_lenght+result.position:distance_to(pos)*(ray_count_count_for_npc - bounce + 1)
			bounced = bounced + 1
			local surface_normal = demonized_geometry_ray.get_surface_normal(pos,dir,nil,nil,result)
			if surface_normal then
				dir = vector():reflect(dir, surface_normal)
			else
				break
			end
			pos = result.position
		else
			break
		end
	end
	return point/getSummation(ray_count_count_for_npc),(bounced <= 0 and lenght) or total_lenght/(getSummation(ray_count_count_for_npc)-getSummation(ray_count_count_for_npc-bounced))
end

function isIndoor(parent)
	if cooldowns_table[parent:id()] and cooldowns_table[parent:id()][1] and cooldowns_table[parent:id()][2] then return cooldowns_table[parent:id()][1],cooldowns_table[parent:id()][2] end
	local dir = parent:direction()
	local horz = dir:getH() -- Range 0 2pi
	local vert = dir:getP()
	local ray_dir_table = {}
	for i,v in pairs(ray_dir_configs_npc) do
		local new_dir = vector():setHP(horz + toRad(v[1]), toRad(v[2]) + vert)
		if v[6] then
        	new_dir = vector():setHP(horz + toRad(v[1]), toRad(v[2]))
		end
        ray_dir_table[i] = {new_dir:normalize(), v[3]}
	end
	-- Do rays_per_tick raycasts per update while cycling through the ray directions table
    for i = 1, #ray_dir_configs_npc do
		lenght_table[i] = {0,ray_dir_configs_npc[i][4] or 1}
		points_table[i] = {0,ray_dir_configs_npc[i][5] or 1}
		points_table[i][1],lenght_table[i][1] = fireRayForNPC(ray_dir_table[i][1],ray_dir_table[i][2],parent)
    end
	local points = 0
	local lenghts = 0
	local pointsMultSum = 0
	local lenghtsMultSum = 0
	for i = 1,#points_table do
		points = points+points_table[i][1]*points_table[i][2]
		lenghts = lenghts+lenght_table[i][1]*lenght_table[i][2]*points_table[i][1]
		pointsMultSum = pointsMultSum+points_table[i][2]
		lenghtsMultSum = lenghtsMultSum+lenght_table[i][2]*points_table[i][1]
	end
	cooldowns_table[parent:id()] = {points/pointsMultSum,lenghts/lenghtsMultSum,mcm_settings.npc_tick_interval[1]}
	return points/pointsMultSum,lenghts/lenghtsMultSum
end

function returnSoundSectionName(alias,section,parent)
	if not parent or not section then return end
	if indoor_snds_callback[alias] and SYS_GetParam(0, section, indoor_snds_callback[alias].."_indoor") then return indoor_snds_callback[alias].."_indoor" end
	if alias == "sndSilencerShot" then
		if SYS_GetParam(0, section, "snd_silncer_shoot_indoor") then return "snd_silncer_shoot_indoor" end
	end
	if parent:id() == AC_ID then
		if string.find(alias,"Actor") then
			local cus_alias = string.gsub(alias,"Actor","")
			if indoor_snds_callback[cus_alias] and SYS_GetParam(0, section, indoor_snds_callback[cus_alias].."_indoor") then return indoor_snds_callback[cus_alias].."_indoor" end
		else
			local cus_alias = alias.."Actor"
			if indoor_snds_callback[cus_alias] and SYS_GetParam(0, section, indoor_snds_callback[cus_alias].."_indoor") then return indoor_snds_callback[cus_alias].."_indoor" end
		end
	end
end

function on_before_play_hud_sound(alias, parent, result)
	if not parent or not (IsStalker(parent) and parent:alive() and db.actor:position():distance_to(parent:position())<75) then return end
	local section = get_wp_sec(parent)
	local line = returnSoundSectionName(alias,section,parent)
	if section and line then
		local score
		local lenghts
		if parent:id() == AC_ID then
			score = env_actorsnd.current_score
			lenghts = env_actorsnd.current_lenght
		end
		if score>mcm_settings.new_threshold[1] then
			result.volume_mult = mcm_settings.volume[1]
			result.section = section
			result.line = line
			-- if string.find(alias,"Shot") and not parent:id() == AC_ID then
			-- 	playTail(parent,score,lenghts)
			-- end
		end
		-- print(score*((parent:id() == AC_ID and env_actorsnd.volume) or mcm_settings.volume[1]))
		-- print(line)
	end
	-- if result.volume_mult == 0 then result.volume_mult = -1 end
end

function actor_on_update()
	if time_global()-last_tick<250 then return end
	for i,v in pairs(cooldowns_table) do
		if cooldowns_table[i] then
			cooldowns_table[i][3] = cooldowns_table[i][3] - (time_global()-last_tick)
			if cooldowns_table[i][3]<0 then
				cooldowns_table[i] = nil
			end
		end
	end
	last_tick = time_global()
end

function actor_on_first_update(wpn,gun)
	RegisterScriptCallback("on_before_play_hud_sound",on_before_play_hud_sound)
	last_tick = time_global()
	on_option_change(true)
end

function on_game_start()
	RegisterScriptCallback("on_option_change",on_option_change)
	-- RegisterScriptCallback("actor_on_update",actor_on_update)
	-- RegisterScriptCallback("actor_on_first_update",actor_on_first_update)
	on_option_change(true)
end
