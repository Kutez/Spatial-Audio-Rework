function print(a,...)
	if mcm_settings.dbug[1] then
		if type(a)=="table" then
			printf("ze table\n%s", utils_data.print_table(a, false, true))
		else
			printf(tostring(a))
		end
	end
end

local sys_param_types = {
    string = 0,
    boolean = 1,
    number = 2
}

function table_find(t,f)
	for i,v in pairs(t) do
		if v == f then
			return i
		end
	end
end

function getAvg(tabl)
	local s = 0
	for i = 1,#tabl do
		s = s+tabl[i]
	end
	return s/#tabl
end

function getSummation(n)
	return n*(n+1)*0.5
end

function toRad(a)
	return a* 0.017453292519943295769236907684886
end

function haveIndoorSound(parent)
	local sec = get_wp_sec(parent)
	if SYS_GetParam(sys_param_types.boolean, sec, "snd_shoot_indoor") == false then return true end
	if SYS_GetParam(sys_param_types.boolean, sec, "snd_shoot_actor_indoor") == false then return true end
	return false
end

function drop_off_equation(n)
	return clamp(4/(4+(n-1)),0.1,1)
end

function clamp(x, min, max)
  return x < min and min or (x > max and max or x)
end

function tail_volume_equation(n) -- Check Desmos again  :)
	return ((n<1 and n^4) or math.max(7.5/(7.5-(n-1)),0.1))
end

function get_wp_sec(parent)
	local wpn = db.actor:active_item()
	if parent then
		if not (IsStalker(parent) and parent:alive()) then return end
		wpn = parent:active_item()
	end
	local sec
	if wpn then
		sec = wpn:section()
	end
	return sec
end

function getSndParamCount(sec,param)
	local paramTabl = {}
	local i = 1
	while ini_sys:r_bool_ex(ini_sys:r_string_ex(sec, param), "snd_"..i.."_layer")==false do
		paramTabl[i] = 0
		while ini_sys:r_bool_ex(ini_sys:r_string_ex(sec, param), "snd_"..i.."_layer"..(paramTabl[i]+1))==false do
			paramTabl[i] = paramTabl[i]+1
		end
		i = i+1
	end
	return paramTabl
end

function isBlackListedMaterial(m)
	for i = 1,#material_black_list do
		if string.find(m,material_black_list[i]) then
			return true
		end
	end
	return false
end

function getPos(parent)
	local pos = db.actor:position()
	if parent then
		pos = parent:position()
	end
	if IsMoveState("mcCrouch") and IsMoveState("mcAccel") then -- Prone
		pos.y = pos.y + 0.4
	elseif IsMoveState("mcCrouch") then
		pos.y = pos.y + 1.2
	else
		pos.y = pos.y + 1.6
	end
	return pos
end


